{
    "name": "fitbox",
    "version": "0.0.1",
    "private": true,
    "scripts": {
        "android": "react-native run-android",
        "androidActive": "react-native run-android --active-arch-only",
        "ios": "react-native run-ios",
        "lint": "eslint \"**/*.{ts,tsx}\" --report-unused-disable-directives --max-warnings 0",
        "start": "react-native start",
        "test": "jest",
        "type-check": "tsc",
        "check-types": "tsc --noEmit --pretty",
        "test:report": "jest --collectCoverage --coverageDirectory=\"./coverage\" --ci --reporters=default --reporters=jest-junit --coverage",
        "pod-install": "cd ios && RCT_NEW_ARCH_ENABLED=1 bundle exec pod install && cd ..",
        "prepare": "husky install"
    },
