        "@react-navigation/elements": "^1.3.21",
        "@react-navigation/native": "^6.1.9",
        "@react-navigation/stack": "^6.3.20",
        "@tanstack/react-query": "^5.8.9",
        "@types/moment": "^2.13.0",
        "i18next": "^23.7.7",
        "immer": "^10.0.4",
